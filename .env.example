# ============================================
# Y-Vault Environment Variables
# ============================================

# === App ===
NEXT_PUBLIC_APP_URL=https://vault.hirahul.xyz
ALLOWED_ORIGINS=http://localhost:3000,https://vault.hirahul.xyz

# === Solana RPC — Helius (primary) ===
# Free tier at https://helius.dev (100K req/day)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
NEXT_PUBLIC_HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# === Solana RPC — QuickNode (round-robin) ===
# Get endpoint at https://www.quicknode.com/
QUICKNODE_RPC_URL=
QUICKNODE_WSS_URL=
NEXT_PUBLIC_QUICKNODE_RPC=

# === Solana RPC — RPC Fast (round-robin) ===
# Get endpoint at https://rpcfast.com/
RPCFAST_RPC_URL=
RPCFAST_WSS_URL=

# === Solana RPC — Helius Devnet (Deriverse DEX) ===
HELIUS_DEVNET_RPC_URL=

# === Supabase (state: watchlist, multi-wallet, price cache) ===
# Free tier at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Birdeye (token price history; primary chart source) ===
# Free key at https://docs.birdeye.so/ → 50 req/min
BIRDEYE_API_KEY=

# === Colosseum Copilot (research, dev-only) ===
COLOSSEUM_COPILOT_API_BASE=https://copilot.colosseum.com/api/v1
COLOSSEUM_COPILOT_PAT=

# === Clerk (authentication) ===
# Get keys at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# === Jupiter (API key) ===
# Optional. Sign up at https://portal.jup.ag — keyless access is 0.5 RPS.
# Free tier with key = 1 RPS; Developer/Launch/Pro tiers available.
JUPITER_API_KEY=

# === Umbra Privacy (encrypted balances, compliance) ===
# No signup needed — these are public endpoints.
# Defaults in constants.ts auto-select devnet if unset.
# Devnet indexer: https://utxo-indexer.api-devnet.umbraprivacy.com
# Mainnet indexer: https://utxo-indexer.api.umbraprivacy.com
NEXT_PUBLIC_UMBRA_NETWORK=devnet
NEXT_PUBLIC_UMBRA_INDEXER_URL=
NEXT_PUBLIC_UMBRA_WSS_RPC=wss://api.devnet.solana.com
