# ============================================
# Y-Vault Environment Variables
# ============================================

# === Dodo Payments (fiat checkout) ===
DODO_PAYMENTS_API_KEY=
DODO_VAULT_PRODUCT_ID=
DODO_PAYMENTS_ENV=test_mode

# === Helius RPC (Solana data) ===
NEXT_PUBLIC_HELIUS_RPC_URL=https://devnet.helius-rpc.com

# === Supabase (persistence) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Colosseum Copilot (research) ===
COLOSSEUM_COPILOT_API_BASE=https://copilot.colosseum.com/api/v1
COLOSSEUM_COPILOT_PAT=

# === Optional ===
NEXT_PUBLIC_QUICKNODE_RPC=
NEXT_PUBLIC_RPC_FAST_URL=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
