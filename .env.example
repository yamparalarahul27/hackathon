# ============================================
# Y-Vault Environment Variables
# ============================================

# === Helius RPC (Solana data) ===
# Use mainnet for real Kamino vault data + Jupiter swaps
# Get free key at https://helius.dev
# Server-only key (recommended)
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# Optional public fallback (avoid in production)
NEXT_PUBLIC_HELIUS_RPC_URL=

# === Supabase (persistence) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Colosseum Copilot (research) ===
COLOSSEUM_COPILOT_API_BASE=https://copilot.colosseum.com/api/v1
COLOSSEUM_COPILOT_PAT=

# === Optional ===
NEXT_PUBLIC_QUICKNODE_RPC=
NEXT_PUBLIC_RPC_FAST_URL=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
